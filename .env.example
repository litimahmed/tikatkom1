# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_MERCHANT_WHATSAPP: The store's WhatsApp number for customer order confirmations (in Algeria format, e.g. +213781913776).
VITE_MERCHANT_WHATSAPP="+213781913776"

# VITE_WORDPRESS_URL: The URL of the headless WordPress installation (e.g. https://mywordpress.com).
# If left blank, it will automatically default to window.location.origin, making it plug-and-play
# when compiled and served directly from the WordPress directory!
VITE_WORDPRESS_URL="http://localhost/tikatkom"

# VITE_API_URL: The URL of the Express Proxy Backend (e.g. http://localhost:3000 in dev, or blank in production to use relative paths).
VITE_API_URL="http://localhost:3000"

# WC_CONSUMER_KEY and WC_CONSUMER_SECRET: Required server-side keys for creating WooCommerce orders.
# Generate these in WordPress: WooCommerce -> Settings -> Advanced -> REST API -> Add Key.
# Ensure the key has Read/Write permissions!
WC_CONSUMER_KEY=""
WC_CONSUMER_SECRET=""

# ZR Express API v1 Credentials (https://api.zrexpress.app/api/v1/parcels)
ZREXPRESS_API_KEY="20GBXOuqTEaIWJOvNL5EogSFDZNtUmffFTsEMCN1M6n4JHwLi3cqttlON9KJ9Gmg"
ZREXPRESS_TENANT_ID="d1dc440e-39ab-4ae7-beb9-783750e06d83"
ZREXPRESS_API_VERSION="v1"

# Lemon Squeezy International Checkout Integration
# VITE_LEMON_SQUEEZY_CHECKOUT_URL: Default hosted checkout link for international buyers (e.g. https://yourstore.lemonsqueezy.com/buy/...)
VITE_LEMON_SQUEEZY_CHECKOUT_URL=""

# LEMON_SQUEEZY_API_KEY: API Key created in Lemon Squeezy -> Settings -> API Keys (for dynamic multi-item carts)
LEMON_SQUEEZY_API_KEY=""

# LEMON_SQUEEZY_STORE_ID: Store ID found in Lemon Squeezy -> Settings -> Stores
LEMON_SQUEEZY_STORE_ID=""

